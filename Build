#!/usr/bin/env bash
set -euo pipefail

CMAKE=${CMAKE:-/usr/bin/cmake}
BUILD_DIR=${BUILD_DIR:-build}
TOOLCHAIN_FILE=${TOOLCHAIN_FILE:-cmake/avr-gcc-toolchain.cmake}

if [[ "${1:-}" == "-c" || "${1:-}" == "--clean" ]]; then
  rm -rf "${BUILD_DIR}"
fi

"${CMAKE}" -S . -B "${BUILD_DIR}" -DCMAKE_TOOLCHAIN_FILE="${TOOLCHAIN_FILE}"
"${CMAKE}" --build "${BUILD_DIR}"
